// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Future proofing for Phase 2/4
  snapshots     Snapshot[]
  profiles      Profile[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Phase 2 - Listening Snapshot
model Snapshot {
  id            String   @id @default(cuid())
  userId        String
  createdAt     DateTime @default(now())
  timeRange     String   // medium_term, short_term, long_term
  snapshotHash  String
  data          String   // JSON string of normalized top artists/tracks
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, snapshotHash])
}

// Phase 4 - AI Profile
model Profile {
  id            String   @id @default(cuid())
  userId        String
  snapshotId    String
  createdAt     DateTime @default(now())
  data          String   // JSON string of archetypes, traits, etc.
  shareSlug     String   @unique @default(cuid())
  isPublic      Boolean  @default(false)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
